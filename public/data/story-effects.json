  "HOOK-05": {
    "title": "Drowned Star's Whisper",
    "onComplete": {
      "survived": {
        "locationOverrides": {
          "old-mill": {
            "extraDetail": "The well behind the mill has gone quiet. The water tastes clean again, though Sibyl watches the surface with an expression that isn't relief."
          },
          "vale-crossroads": {
            "extraDetail": "The wells no longer taste of salt. Children sleep soundly again, though their parents remember the dreams they can't quite name."
          }
        },
        "npcDialogueFlags": {
          "sibyl": ["knows_about_drowned_star", "grateful_for_lanterns"],
          "edric": ["heard_about_salt_wells"]
        },
        "factionRepBonus": {
          "pale_court": 10
        }
      },
      "died": {
        "locationOverrides": {
          "vale-crossroads": {
            "extraDetail": "The wells still taste of salt. Parents whisper about the dreams their children can't shake, and the name they keep repeating — yours."
          }
        },
        "npcDialogueFlags": {
          "sibyl": ["sensed_player_death", "knows_about_drowned_star"],
          "edric": ["heard_about_salt_wells", "wary_of_player"]
        },
        "factionRepBonus": {}
      }
    }
  },
  "HOOK-06": {
    "title": "Veilbound Audit",
    "onComplete": {
      "survived": {
        "locationOverrides": {
          "vale-crossroads": {
            "extraDetail": "The Inquisition auditors have departed. Their marks remain on doorframes — white sigils that haven't yet faded. But you're still standing."
          },
          "thornwatch-inn": {
            "extraDetail": "Maren keeps glancing at the door, as though expecting the Inquisition to return. But they haven't. Not yet."
          }
        },
        "npcDialogueFlags": {
          "maren": ["trusts_player", "survived_audit"],
          "edric": ["respects_player", "knows_about_audit"],
          "sibyl": ["heard_about_audit"]
