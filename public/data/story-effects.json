        "factionRepBonus": {
          "inquisition": -10
        }
      },
      "died": {
        "locationOverrides": {
          "vale-crossroads": {
            "extraDetail": "The Inquisition's audit concluded without incident — for them. Your name has been added to their register of 'resolved cases.'"
          }
        },
        "npcDialogueFlags": {
          "maren": ["mourns_audit_loss"],
          "edric": ["knows_about_audit", "wary_of_player"],
          "sibyl": ["sensed_player_death"]
